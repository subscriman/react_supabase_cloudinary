{
  "name": "subscription-manager",
  "version": "1.0.0",
  "description": "구독/멤버십 관리 앱 템플릿 (React Native + Next.js + Supabase + Cloudinary)",
  "main": "index.js",
  "scripts": {
    "setup": "npm run setup:mobile && npm run setup:web",
    "setup:mobile": "cd mobile && npm install",
    "setup:web": "cd web && npm install",
    "dev:mobile": "cd mobile && npm start",
    "dev:web": "cd web && npm run dev",
    "build:web": "cd web && npm run build",
    "cloudinary:setup": "echo 'Please follow docs/cloudinary-setup.md to configure Cloudinary'"
  },
  "keywords": [
    "subscription",
    "management",
    "react-native",
    "supabase",
    "template",
    "starter",
    "nextjs",
    "netlify"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=18 <21"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.89.0",
    "cloudinary": "^2.8.0",
    "cloudinary-react": "^1.8.1",
    "dotenv": "^17.2.3"
  }
}
