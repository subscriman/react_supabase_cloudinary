{
  "name": "arttomato",
  "version": "1.0.0",
  "description": "ArtTomato web-first exhibition discovery and review service",
  "main": "index.js",
  "scripts": {
    "setup": "npm run setup:mobile && npm run setup:web",
    "setup:mobile": "cd mobile && npm install",
    "setup:web": "cd web && npm install",
    "dev:mobile": "cd mobile && npm start",
    "dev:web": "cd web && npm run dev",
    "build:web": "cd web && npm run build",
    "env:check": "node scripts/check-env.js",
    "supabase:auth-check": "node scripts/check-auth-providers.js",
    "supabase:admin-check": "node scripts/check-admin-users.js",
    "supabase:users": "node scripts/list-auth-users.js",
    "supabase:key-check": "node scripts/check-supabase-keys.js",
    "supabase:rls-check": "node scripts/check-rls.js",
    "supabase:functions:deploy:daegu-test": "supabase functions deploy daegu-connect-test --no-verify-jwt",
    "supabase:functions:invoke:daegu-test": "node scripts/invoke-daegu-connect-test.js",
    "supabase:grant-admin": "node scripts/grant-admin.js",
    "qa:smoke-web": "node scripts/smoke-web.js",
    "qa:manual-flows": "node scripts/qa-manual-flows.js",
    "alerts:start-run": "node scripts/alerts/run-start-alerts.js",
    "llm:test": "node scripts/test-llm.js",
    "ingest:run": "node scripts/ingestion/run.js",
    "ingest:audit-sites": "node scripts/ingestion/audit-sites.js",
    "ingest:daegu:audit": "INGESTION_ENABLE_DAEGU_ART=true node scripts/ingestion/audit-sites.js --site=daegu-art --sample=2 --output=docs/수집_사이트_진단_리포트_daegu.md",
    "ingest:daegu:dry-run": "INGESTION_ENABLE_DAEGU_ART=true node scripts/ingestion/run.js --site=daegu-art --dry-run --limit=20",
    "ingest:daegu:audit:edge": "INGESTION_ENABLE_DAEGU_ART=true INGESTION_DAEGU_USE_EDGE_FETCH=true node scripts/ingestion/audit-sites.js --site=daegu-art --sample=2 --output=docs/수집_사이트_진단_리포트_daegu.md",
    "ingest:daegu:dry-run:edge": "INGESTION_ENABLE_DAEGU_ART=true INGESTION_DAEGU_USE_EDGE_FETCH=true node scripts/ingestion/run.js --site=daegu-art --dry-run --limit=20"
  },
  "keywords": [
    "arttomato",
    "exhibition",
    "reviews",
    "nextjs",
    "supabase"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=18 <21"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.89.0",
    "cloudinary": "^2.8.0",
    "cloudinary-react": "^1.8.1",
    "dotenv": "^17.2.3"
  }
}
